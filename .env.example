# ── Betfair Exchange API ──────────────────────────────────────────────────────
# Your Betfair account credentials
BETFAIR_USERNAME=your_betfair_username
BETFAIR_PASSWORD=your_betfair_password
# Application key from My Account > API Access > Developer App Keys
BETFAIR_APP_KEY=your_betfair_app_key

# ── Racing API (racingapi.io) ──────────────────────────────────────────────────
RACING_API_KEY=your_racing_api_key
# Base URL — update if racingapi.io changes
RACING_API_BASE=https://api.racingapi.io/v1

# ── The Odds API (the-odds-api.com) ───────────────────────────────────────────
# Free tier: 500 requests/month. Sign up at https://the-odds-api.com
# Provides best-available odds across Bet365, William Hill, Ladbrokes, etc.
ODDS_API_KEY=your_odds_api_key

# ── App Settings ──────────────────────────────────────────────────────────────
PORT=3000
# Set to "true" to use mock data even when live API keys are present
USE_MOCK_DATA=true
# Polling interval in seconds (default 60)
POLL_INTERVAL=60
